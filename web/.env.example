# Copy to `.env.local` for local development (`npm run dev`).

# Public API base URL (no trailing slash). The browser calls this directly — it must be
# reachable from the user’s machine (same host/port you use in the address bar for the API).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production / Docker Compose (browser on host → API port on host):
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Deployed split stack (example): set at **build time** to your public API URL, e.g.
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# Backend must allow your site origin in KA_CORS_ORIGINS (see repository root .env.example).
