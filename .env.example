# Tracked sample only — copy ideas to gitignored `.env.local` or set vars in the shell.
# Never commit a real OPENAI_API_KEY to any file in the repo.
#
# Secret order (Python app / eval): process environment wins; then `.env.local` overrides
# `.env` for keys the process did not set. This file is NOT loaded at runtime.
#
# Quick local setup:
#   1. Copy `.env.local.template` to `.env.local`
#   2. Replace the placeholder below with your real key (keep `.env.local` gitignored)

# --- Required for embeddings + chat ---
OPENAI_API_KEY=your_openai_api_key_here

# Optional: helps some Windows shells when not set globally (Python also sets via launch scripts)
# PYTHONPATH=.

# --- FastAPI / production ---
# KA_ENV=production
# KA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Data directories (defaults under ./data/)
# KA_RAW_DIR=
# KA_FAISS_DIR=

# Chunking / retrieval
# KA_DEFAULT_CHUNK_SIZE=500
# KA_DEFAULT_CHUNK_OVERLAP=80
# KA_DEFAULT_TOP_K=3

# KA_MAX_UPLOAD_BYTES=52428800

# --- Optional behavior ---
# KA_DEBUG=1
# KA_NO_STREAM=1
# KA_RETRIEVAL_DEBUG=1
# PYTHONUNBUFFERED=1

# Web search
# WEB_SEARCH_ENABLED=1

# Optional: OCR fallback for image-only PDF pages (requires requirements-optional-ocr.txt + Tesseract + Poppler)
# RAG_ENABLE_PDF_OCR=1

# Performance (hybrid retrieval): in-process BM25 corpus cache (default on). Set to 0 to disable.
# KA_BM25_CACHE=0
# Optional: skip BM25 cache when chunk count exceeds this (falls back to per-query build)
# KA_BM25_CACHE_MAX_DOCS=20000
