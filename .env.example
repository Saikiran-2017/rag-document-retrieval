# Sample configuration only — copy to gitignored files or set vars in the host environment.
# Public repo: do NOT put a real OPENAI_API_KEY in any tracked file.
#
# Priority (each variable):
#   1. Process environment (Render, Docker, shell) — wins
#   2. .env (gitignored) — optional local defaults
#   3. .env.local (gitignored) — overrides .env for keys the process did not set
#
# Local setup (pick one):
#   - PowerShell:  $env:OPENAI_API_KEY="sk-..."
#   - CMD:         set OPENAI_API_KEY=sk-...
#   - File:        copy this to .env.local and replace the placeholder below

# --- Required for LLM / embeddings ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- FastAPI / production ---
# production | prod | 1  → hide /docs and /redoc
# KA_ENV=production

# Browser origins allowed to call the API (comma-separated). Required for the Next.js UI when not using defaults.
# KA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Data directories (defaults: ./data/raw and ./data/indexes under project root)
# KA_RAW_DIR=
# KA_FAISS_DIR=

# Chunking / retrieval defaults for API + Streamlit
# KA_DEFAULT_CHUNK_SIZE=500
# KA_DEFAULT_CHUNK_OVERLAP=80
# KA_DEFAULT_TOP_K=3

# Uploads (API + Streamlit save path)
# KA_MAX_UPLOAD_BYTES=52428800

# --- Optional behavior ---
# KA_DEBUG=1
# KA_NO_STREAM=1
# KA_RELIABILITY_LOG=1
# KA_PERF_LOG=0
# KA_NO_REWRITE=1

# Web search (duckduckgo-search)
# WEB_SEARCH_ENABLED=1
# WEB_MAX_LLM_RESULTS=

# Python
# PYTHONUNBUFFERED=1
