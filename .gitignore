# Virtual environment
.venv/
venv/
env/

# Environment and secrets (never commit real API keys)
.env
.env.local
.env.*
*.env
!.env.example
!.env.local.template
*.pem

private_docs/

# Local eval console capture and ad-hoc logs (never commit)
eval/_stdout*.txt
eval/_phase20f*.txt
eval/*_stderr.txt
eval/*_stdout.txt
eval/_phase*_*/            # real-doc packs / smoke work dirs
eval/**/embedding_cache/   # local embedding cache artifacts
eval/**/*.npy
eval/**/*.faiss
eval/**/*.pkl
eval/**/index_library_state.json
eval/**/document_manifest.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml

# Local data (uploads and indexes - adjust if you want to track small samples)
data/raw/*
!data/raw/.gitkeep
!data/raw/sample_phase2.txt
data/indexes/*
!data/indexes/.gitkeep

# Eval harness temp index
eval/_work/
eval/_report*.json

# Playwright / web E2E (if generated at repo root)
test-results/
playwright-report/
playwright/.cache/
web/tests-e2e/.e2e-work/
